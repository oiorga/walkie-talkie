<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- If your app targets Android 13 (API level 33)
        or higher, you must declare the NEARBY_WIFI_DEVICES permission. -->
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s" />
    <!-- If your app derives location information from Wi-Fi APIs,
         don't include the "usesPermissionFlags" attribute. -->
    <uses-permission
        android:required="true"
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="35"/>

    <uses-permission
        android:required="true"
        android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="35"/>

    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- android:name="android.permission.ACCESS_COARSE_LOCATION" -->
    <!-- If any feature in your app relies on precise location information,
         don't include the "maxSdkVersion" attribute. -->
    <!-- android:label="@string/app_label" -->
    <uses-permission
        android:required="true"
        android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission
        android:required="true"
        android:name="android.permission.CHANGE_WIFI_STATE"/>
    <uses-permission
        android:required="true"
        android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_wt_02"
        android:label="${baseName}${appFlavour}${appType}"
        android:roundIcon="@mipmap/ic_launcher_wt_02"
        android:supportsRtl="true"
        android:theme="@style/Theme.Splash"
        tools:replace="android:theme"
        tools:targetApi="31"
        android:process="@string/app_name">
        <profileable android:shell="true" />
        <activity
            android:windowSoftInputMode="adjustResize"
            android:name=".WalkieTalkie"
            android:exported="true"
            android:theme="@style/Theme.Splash">
            <!-- android:launchMode="singleInstancePerTask" -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
