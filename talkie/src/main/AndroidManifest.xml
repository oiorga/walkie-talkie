<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Pre-Android 13 (API 32 and below) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Android 13+ -->
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="33" />

    <!--
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    -->

    <uses-permission
        android:name="android.permission.ACCESS_WIFI_STATE"/>
    <uses-permission
        android:name="android.permission.CHANGE_WIFI_STATE"/>
    <uses-permission
        android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_wt_02"
        android:label="${baseName}${appFlavour}${appType}"
        android:roundIcon="@mipmap/ic_launcher_wt_02"
        android:supportsRtl="true"
        android:theme="@style/Theme.Splash"
        tools:replace="android:theme"
        tools:targetApi="31"
        android:process="@string/app_name">
        <profileable android:shell="true" />
        <activity
            android:windowSoftInputMode="adjustResize"
            android:name=".WTActivity"
            android:exported="true"
            android:theme="@style/Theme.Splash">
            <!-- android:launchMode="singleInstancePerTask" -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
